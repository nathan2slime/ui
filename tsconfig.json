{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "useDefineForClassFields": true,
    "paths": {
      "@/*": ["./src/*"],
      "styled-system/*": ["./styled-system/*"],
      "ui": ["."]
    }
  },
  "include": [
    "src",
    "stories",
    "docs",
    ".storybook",
    "tests",
    "rspress.config.ts"
  ]
}
