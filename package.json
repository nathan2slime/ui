  },
  "scripts": {
    "build": "rslib build --tsconfig tsconfig.build.json",
    "build:storybook": "storybook build",
    "check": "biome check .",
    "changeset": "changeset",
    "dev": "rslib build --watch --tsconfig tsconfig.build.json",
    "doc": "rspress dev",
    "doc:build": "rspress build",
    "doc:preview": "rspress preview",
    "format": "biome format --write",
    "lint": "biome check .",
    "release": "pnpm run build && changeset publish --provenance",
    "storybook": "storybook dev --port 6006",
    "typecheck": "tsc --noEmit",
    "test": "rstest",
    "test:coverage": "rstest --coverage",
    "test:watch": "rstest --watch",
    "version-packages": "changeset version"
  },
  "devDependencies": {
