    "@types/react": "^19.2.14",
    "happy-dom": "^20.8.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rsbuild-plugin-workspace-dev": "^0.1.4",
    "storybook": "^10.2.19",
    "storybook-addon-rslib": "^3.3.2",
    "storybook-react-rsbuild": "^3.3.2",
    "typescript": "^5.9.3"
